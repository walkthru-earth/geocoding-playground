{
  "name": "@walkthru-earth/geocoding-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Framework-agnostic geocoding engine powered by DuckDB-WASM and Overture Maps data",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@duckdb/duckdb-wasm": ">=1.28.0"
  },
  "devDependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev44.0",
    "@vitest/coverage-v8": "^4.1.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.7",
    "vite-plugin-dts": "5.0.0-beta.6",
    "vitest": "^4.1.3"
  }
}
